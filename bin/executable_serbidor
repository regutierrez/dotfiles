#!/usr/bin/env python3
"""Serve a file's directory over HTTP and print the file URL."""

import argparse
import functools
import socket
import sys
from http.server import HTTPServer, SimpleHTTPRequestHandler
from pathlib import Path
from typing import cast


# NOTE: browsers will probably block downloads because this is served via HTTP. if you need to download, just `curl -L -o <link>`
def main():
    parser = argparse.ArgumentParser(description="Serve a file over HTTP")
    _ = parser.add_argument("filepath", type=Path, help="File to serve")
    args = parser.parse_args()

    filepath = cast(Path, args.filepath).resolve()
    if not filepath.is_file():
        print(f"error: {filepath} is not a file", file=sys.stderr)
        sys.exit(1)

    handler = functools.partial(
        SimpleHTTPRequestHandler, directory=str(filepath.parent)
    )
    server = HTTPServer(("0.0.0.0", 0), handler)
    port = server.server_port

    print(f"Serving {filepath.parent}", flush=True)
    print(f"http://{socket.gethostname()}:{port}/{filepath.name}", flush=True)
    print(flush=True)

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopped.")
        server.server_close()


if __name__ == "__main__":
    main()
