#!/usr/bin/env python3
"""Serve a single file over HTTP."""

import argparse
import functools
import os
import socket
import sys
from http.server import HTTPServer, SimpleHTTPRequestHandler
from pathlib import Path


def find_open_port() -> int:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(("", 0))
        return s.getsockname()[1]


class SingleFileHandler(SimpleHTTPRequestHandler):
    """Handler that serves only one specific file."""

    def __init__(self, filepath: Path, *args, **kwargs):
        self.filepath = filepath
        super().__init__(*args, directory=str(filepath.parent), **kwargs)

    def translate_path(self, path: str) -> str:
        # No matter what path is requested, serve the one file
        return str(self.filepath)

    def log_message(self, format, *args):
        print(f"  {args[0]}")


def main():
    parser = argparse.ArgumentParser(description="Serve a single file over HTTP")
    parser.add_argument("filepath", type=Path, help="File to serve")
    parser.add_argument("-p", "--port", type=int, default=0, help="Port (default: auto)")
    args = parser.parse_args()

    filepath = args.filepath.resolve()
    if not filepath.is_file():
        print(f"error: {filepath} is not a file", file=sys.stderr)
        sys.exit(1)

    port = args.port or find_open_port()
    handler = functools.partial(SingleFileHandler, filepath)
    server = HTTPServer(("0.0.0.0", port), handler)

    print(f"Serving {filepath.name}", flush=True)
    print(f"http://localhost:{port}/{filepath.name}", flush=True)
    print(flush=True)

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopped.")
        server.server_close()


if __name__ == "__main__":
    main()
