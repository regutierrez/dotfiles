#!/bin/sh
# agent-status-cursor-hook — adapter between cursor-agent hooks and agent-status.
#
# Cursor pipes JSON context on stdin and blocks on broken pipes, so it must be
# drained before doing anything else. Referenced from ~/.cursor/hooks.json.
#
# usage: agent-status-cursor-hook <attention|busy|done|clear>
cat >/dev/null 2>&1

case "${1:-}" in
clear) exec "$HOME/bin/agent-status" clear ;;
attention | busy | done) exec "$HOME/bin/agent-status" update cursor "$1" ;;
*) exit 0 ;;
esac
