#!/bin/sh
# agent-status-claude-notify — adapter for Claude Code's Notification hook.
#
# Notification fires both for real blockers ("Claude needs your permission to
# use X") and for the 60s idle reminder ("Claude is waiting for your input").
# Only the former means needs-intervention; the idle reminder would flip
# finished sessions from done back to attention, so anything else is ignored.
payload=$(cat 2>/dev/null)

# cursor-agent emulates Claude Code hooks with its own payloads; only react
# when invoked by real Claude Code (see agent-status-claude-hook).
[ "${CLAUDECODE:-}" = "1" ] || exit 0

case "$payload" in
*[Pp]ermission*) exec "$HOME/bin/agent-status" update claude attention ;;
*) exit 0 ;;
esac
