#!/usr/bin/env bash
set -euo pipefail

root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$root"

fail=0
ok() { printf 'ok: %s\n' "$1"; }
bad() { printf 'FAIL: %s\n' "$1" >&2; fail=1; }

assert_contains() {
  local file="$1"
  local needle="$2"
  local msg="$3"
  if grep -Fq -- "$needle" "$file"; then
    ok "$msg"
  else
    bad "$msg"
  fi
}

profiles=$(python3 - <<'PY'
import tomllib
with open('.chezmoidata.toml', 'rb') as f:
    data = tomllib.load(f)
print('\n'.join(data['profiles'].keys()))
PY
)

# README: human-facing profile/package/Cachy docs
while IFS= read -r profile; do
  [[ -n "$profile" ]] || continue
  assert_contains README.md "$profile" "README mentions profile '$profile'"
done <<< "$profiles"

for flag in tmux_plugins manage_bashrc manage_vimrc manage_nvim manage_bin manage_dot_config manage_agents use_age; do
  assert_contains README.md "$flag" "README mentions profile flag '$flag'"
done

for path in \
  'dot_config/kitty/' \
  'dot_config/niri/' \
  'dot_config/systemd/user/dms-auto-resolution-profile.service' \
  'dot_local/bin/executable_dms-auto-resolution-profile'; do
  assert_contains README.md "$path" "README mentions CachyGaming path '$path'"
done

# AGENTS: agent workflow essentials (no duplicate of README prose)
assert_contains AGENTS.md ".chezmoidata.toml" "AGENTS references profile data source"
assert_contains AGENTS.md ".chezmoiignore" "AGENTS mentions .chezmoiignore gates"
assert_contains AGENTS.md "manage_agents" "AGENTS mentions manage_agents flag"
assert_contains AGENTS.md "bootstrap" "AGENTS mentions bootstrap gating"
assert_contains AGENTS.md "README.md" "AGENTS points human docs to README"

if [[ -e .agents/skills/chezmoi/SKILL.md ]]; then
  bad 'retired chezmoi skill still exists; AGENTS.md is source of truth'
else
  ok 'retired chezmoi skill absent'
fi

for legacy in dot_agents/skills/build-skill dot_agents/skills/diagnose dot_agents/skills/teach-me; do
  if [[ -e "$legacy" ]]; then
    bad "legacy active skill still exists: $legacy"
  else
    ok "legacy active skill absent: $legacy"
  fi
done

for current in dot_agents/skills/writing-great-skills dot_agents/skills/diagnosing-bugs; do
  if [[ -d "$current" ]]; then
    ok "current skill exists: $current"
  else
    bad "expected current skill missing: $current"
  fi
done

agents_lines=$(wc -l < AGENTS.md | tr -d ' ')
if (( agents_lines <= 150 )); then
  ok "AGENTS.md <= 150 lines ($agents_lines)"
else
  bad "AGENTS.md too long ($agents_lines lines)"
fi

if grep -Fq '"manage_agents" true' .chezmoiignore; then
  ok '.chezmoiignore fallback keeps server manage_agents true'
else
  bad '.chezmoiignore fallback may not match server manage_agents=true'
fi

exit "$fail"
