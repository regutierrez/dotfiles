#!/usr/bin/env bash

set -euo pipefail

eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null)" || true

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
ROOTS_FILE="$XDG_CONFIG_HOME/commando/roots"
BASE_CONFIG="$XDG_CONFIG_HOME/sesh/sesh.toml"
CACHE_DIR="$XDG_CACHE_HOME/commando"
GENERATED_SESSIONS="$CACHE_DIR/sessions.toml"
GENERATED_CONFIG="$CACHE_DIR/sesh.toml"

command -v sesh >/dev/null 2>&1 || {
  printf 'sesh is required. Install with: brew install sesh\n' >&2
  if [[ -t 0 ]]; then
    printf 'Press enter to close...'
    read -r _
  fi
  exit 1
}

default_roots() {
  printf '%s\t%s\n' \
    'repos' '~/repos' \
    'playground' '~/playground' \
    'config' '~/.config'
}

load_roots() {
  local source="$ROOTS_FILE"
  local line label path

  if [[ -f "$source" ]]; then
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      [[ "$line" =~ ^[[:space:]]*# ]] && continue

      IFS=$'\t' read -r label path <<<"$line"
      [[ -n "${label:-}" && -n "${path:-}" ]] || continue

      printf '%s\t%s\n' "$label" "$path"
    done < "$source"
  else
    default_roots
  fi
}

expand_home() {
  local path="$1"

  case "$path" in
    '~')
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s\n' "$HOME/${path:2}"
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

escape_toml_string() {
  local value="$1"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  printf '%s\n' "$value"
}

write_generated_session_entry() {
  local name="$1"
  local path="$2"

  printf '[[session]]\n'
  printf 'name = "%s"\n' "$(escape_toml_string "$name")"
  printf 'path = "%s"\n\n' "$(escape_toml_string "$path")"
}

write_generated_sessions() {
  local label root dir name path

  mkdir -p "$CACHE_DIR"

  {
    printf '# Generated by commando. Do not edit.\n\n'

    while IFS=$'\t' read -r label root; do
      [[ -n "$label" && -n "$root" ]] || continue

      root="$(expand_home "$root")"
      [[ -d "$root" ]] || continue

      for dir in "$root"/*; do
        [[ -d "$dir" ]] || continue
        name="${label}/$(basename "$dir")"
        path="$dir"

        write_generated_session_entry "$name" "$path"
      done
    done < <(load_roots)
  } > "$GENERATED_SESSIONS"
}

write_generated_config() {
  local import_path

  mkdir -p "$CACHE_DIR"
  import_path="$(escape_toml_string "$GENERATED_SESSIONS")"

  {
    printf 'import = ["%s"]\n\n' "$import_path"
    if [[ -f "$BASE_CONFIG" ]]; then
      cat "$BASE_CONFIG"
    else
      printf '[default_session]\n'
      printf 'preview_command = "eza --all --git --icons --color=always {}"\n'
    fi
  } > "$GENERATED_CONFIG"
}

prepare_generated_config() {
  write_generated_sessions
  write_generated_config
}

run_fzf_tmux_picker() {
  command -v fzf-tmux >/dev/null 2>&1 || {
    printf 'fzf-tmux is required.\n' >&2
    exit 1
  }
  command -v fd >/dev/null 2>&1 || {
    printf 'fd is required.\n' >&2
    exit 1
  }
  command -v rg >/dev/null 2>&1 || {
    printf 'rg is required.\n' >&2
    exit 1
  }

  local config_quoted selected
  local all_cmd tmux_cmd configs_cmd repos_cmd playground_cmd config_dirs_cmd dotfiles_cmd zoxide_cmd find_cmd

  config_quoted="$(printf '%q' "$GENERATED_CONFIG")"
  all_cmd="sesh -C ${config_quoted} list --icons -d -H"
  tmux_cmd="sesh -C ${config_quoted} list -t --icons -d -H"
  configs_cmd="sesh -C ${config_quoted} list -c --icons -d -H"
  repos_cmd="${configs_cmd} | rg 'repos/'"
  playground_cmd="${configs_cmd} | rg 'playground/'"
  config_dirs_cmd="${configs_cmd} | rg 'config/'"
  dotfiles_cmd="${configs_cmd} | rg 'dotfiles'"
  zoxide_cmd="sesh -C ${config_quoted} list -z --icons -d -H"
  find_cmd="fd -H -d 2 -t d -E .Trash . ~"

  selected="$(eval "$all_cmd" | fzf-tmux -p 80%,70% \
    --no-sort --ansi --border-label ' commando + sesh ' --prompt '⚡  ' \
    --header '  ^a all ^t tmux ^r repos ^p playground ^c config ^d dotfiles ^z zoxide ^x tmux kill ^f find' \
    --bind 'tab:down,btab:up' \
    --bind "ctrl-a:change-prompt(⚡  )+reload(${all_cmd})" \
    --bind "ctrl-t:change-prompt(🪟  )+reload(${tmux_cmd})" \
    --bind "ctrl-r:change-prompt(📦  )+reload(${repos_cmd})" \
    --bind "ctrl-p:change-prompt(🧪  )+reload(${playground_cmd})" \
    --bind "ctrl-c:change-prompt(⚙️  )+reload(${config_dirs_cmd})" \
    --bind "ctrl-d:change-prompt(🏠  )+reload(${dotfiles_cmd})" \
    --bind "ctrl-z:change-prompt(📁  )+reload(${zoxide_cmd})" \
    --bind "ctrl-f:change-prompt(🔎  )+reload(${find_cmd})" \
    --bind "ctrl-x:execute(tmux kill-session -t {2..})+change-prompt(⚡  )+reload(${all_cmd})" \
    --preview-window 'right:55%' \
    --preview "sesh -C ${config_quoted} preview {}")" || exit 0

  [[ -n "$selected" ]] || exit 0
  exec sesh -C "$GENERATED_CONFIG" connect "$selected"
}

case "${1:-}" in
  --prepare)
    prepare_generated_config
    exit 0
    ;;
  --config-path)
    prepare_generated_config
    printf '%s\n' "$GENERATED_CONFIG"
    exit 0
    ;;
  --fzf-tmux)
    prepare_generated_config
    run_fzf_tmux_picker
    exit 0
    ;;
esac

prepare_generated_config

exec sesh -C "$GENERATED_CONFIG" picker -i -d -H
