#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///
"""
syncr: Sync skills from repos to dotfiles

Discovers repos in ~/.cache/syncr/ and syncs their skills to dotfiles.

Commands:
  add <repo-url>  Clone a repo to the cache
  status          Show discovered repos and their skills
  check           Check which skills need updating
  pull            Pull latest changes for all cached repos
  sync            Sync skills to dotfiles and commit
  select          Interactively select which skills to sync
"""

import argparse
import re
import subprocess
import sys
from pathlib import Path
from typing import cast

# Configuration
CACHE_ROOT = Path.home() / ".cache" / "syncr"
DOTFILES_SKILLS = Path.home() / "repos" / "dotfiles" / "dot_agents" / "skills"


def parse_repo_url(repo_input: str) -> tuple[str, str, str] | None:
    """Parse a repo URL into (host, org, repo). Returns None if not a URL."""
    repo_input = repo_input.strip()

    # Strip query/fragment
    repo_input = repo_input.split("?")[0].split("#")[0]

    host = ""
    path = ""

    # Handle different URL formats
    if repo_input.startswith("git@"):
        # git@github.com:owner/repo.git
        match = re.match(r"git@([^:]+):(.+)", repo_input)
        if match:
            host = match.group(1)
            path = match.group(2)
    elif repo_input.startswith(("http://", "https://")):
        # https://github.com/owner/repo
        rest = repo_input.split("://", 1)[1]
        parts = rest.split("/", 1)
        if len(parts) >= 2:
            host = parts[0]
            path = parts[1]
    else:
        # Not a URL
        return None

    if not host or not path:
        return None

    # Clean up path
    path = path.lstrip("/").rstrip("/")
    path = path.removesuffix(".git")

    # Handle deep links (tree/blob/pull etc)
    parts = path.split("/")
    if len(parts) >= 3 and parts[2] in (
        "tree",
        "blob",
        "pull",
        "issues",
        "commit",
        "actions",
        "releases",
        "compare",
        "wiki",
    ):
        path = f"{parts[0]}/{parts[1]}"
        parts = path.split("/")

    if len(parts) < 2:
        return None

    repo = parts[-1]
    org = "/".join(parts[:-1])

    return (host, org, repo)


def clone_repo(host: str, org: str, repo: str) -> Path:
    """Clone a repo to the cache directory. Returns the path."""
    checkout_path = CACHE_ROOT / org / repo
    repo_url = f"https://{host}/{org}/{repo}.git"

    if checkout_path.exists():
        print(f"  Repo already exists at {checkout_path}")
        return checkout_path

    print(f"  Cloning {repo_url}...")
    _ = checkout_path.parent.mkdir(parents=True, exist_ok=True)

    _ = subprocess.run(
        ["git", "clone", "--filter=blob:none", repo_url, str(checkout_path)],
        check=True,
        capture_output=True,
    )
    print("  ✓ Cloned")

    return checkout_path


def cmd_pull() -> None:
    """Pull latest changes for all cached repos."""
    repos = discover_cached_repos()

    if not repos:
        print(f"No cached repos found in {CACHE_ROOT}")
        return

    print(f"Pulling latest changes for {len(repos)} repo(s)...\n")

    for repo_path in repos:
        print(f"  Updating {repo_path}...")
        try:
            _ = subprocess.run(
                ["git", "-C", str(repo_path), "pull"],
                check=True,
                capture_output=True,
                text=True,
            )
            print("    ✓ Updated")
        except subprocess.CalledProcessError as e:
            print(f"    ✗ Update failed: {e.stderr.strip()}")


def cmd_add(repo_url: str) -> None:
    """Add a repo by cloning it to the cache."""
    parsed = parse_repo_url(repo_url)

    if not parsed:
        print(f"Error: Cannot parse repo URL: {repo_url}")
        print("Supported formats: owner/repo, https://..., git@...")
        sys.exit(1)

    host, org, repo = parsed
    print(f"Adding {host}/{org}/{repo}...")
    path = clone_repo(host, org, repo)

    # Show what skills are available
    skills = get_repo_skills(path)
    if skills:
        print(f"\nFound {len(skills)} skill(s):")
        for skill in skills:
            print(f"  - {skill}")
    else:
        print("\nNo skills found in this repo.")

    print(f"\nRepo location: {path}")


def discover_cached_repos() -> list[Path]:
    """Find all repos in the cache directory."""
    repos: list[Path] = []

    if not CACHE_ROOT.exists():
        return repos

    # Structure: ~/.cache/syncr/<org>/<repo>
    for org_dir in CACHE_ROOT.iterdir():
        if not org_dir.is_dir():
            continue
        for repo_dir in org_dir.iterdir():
            if repo_dir.is_dir() and (repo_dir / ".git").exists():
                repos.append(repo_dir)

    return sorted(repos)


def get_repo_skills(repo_path: Path) -> list[str]:
    """Get list of skills in the repo. A skill is any directory containing SKILL.md."""
    skills: set[str] = set()

    # Walk through all directories looking for SKILL.md
    for path in repo_path.rglob("SKILL.md"):
        if path.is_file():
            # The skill is the directory containing SKILL.md
            skill_dir = path.parent
            skills.add(skill_dir.name)

    return sorted(skills)


def find_skill_sources(skill_name: str) -> list[Path]:
    """Find all cached repos that have this skill (directory containing SKILL.md)."""
    repos = discover_cached_repos()
    sources: list[Path] = []

    for repo_path in repos:
        # Look for skill directory with SKILL.md
        skill_path = repo_path / skill_name / "SKILL.md"
        if skill_path.exists() and skill_path.is_file():
            sources.append(repo_path / skill_name)
            continue
        # Also search recursively
        for skill_file in repo_path.rglob("SKILL.md"):
            if skill_file.parent.name == skill_name:
                sources.append(skill_file.parent)
                break

    return sources

def find_skill_source(skill_name: str) -> Path | None:
    """Find which cached repo has this skill."""
    # If the user provided org/repo/skill
    if "/" in skill_name:
        parts = skill_name.rsplit("/", 1)
        if len(parts) == 2:
            repo_part, actual_skill = parts
            sources = find_skill_sources(actual_skill)
            for src in sources:
                if repo_part in str(src):
                    return src
            return None

    sources = find_skill_sources(skill_name)
    if not sources:
        return None
    if len(sources) > 1:
        # For non-interactive usage, we'll try to find the one that matches the current dotfiles content
        # Or just return the most recently modified one? Let's just return the first one but maybe we should warn?
        # Actually, if we're in `needs_update` or `sync_skill`, we'll handle this.
        pass
    return sources[0]


def get_skill_mtime(skill_path: Path) -> float:
    """Get modification time of a skill directory."""
    if not skill_path.exists():
        return 0
    return max(f.stat().st_mtime for f in skill_path.rglob("*") if f.is_file())


def needs_update(skill_name: str) -> bool:
    """Check if skill in dotfiles differs from source."""
    source_path = find_skill_source(skill_name)
    if not source_path:
        return False

    actual_skill = skill_name.rsplit("/", 1)[-1] if "/" in skill_name else skill_name
    dotfiles_path = DOTFILES_SKILLS / actual_skill

    if not dotfiles_path.exists():
        return True

    source_files = {f.relative_to(source_path): f for f in source_path.rglob("*") if f.is_file() and ".git" not in f.parts}
    dotfiles_files = {f.relative_to(dotfiles_path): f for f in dotfiles_path.rglob("*") if f.is_file() and ".git" not in f.parts}

    if set(source_files.keys()) != set(dotfiles_files.keys()):
        return True

    for rel_path in source_files:
        try:
            if source_files[rel_path].read_bytes() != dotfiles_files[rel_path].read_bytes():
                return True
        except Exception:
            return True

    return False


def sync_skill(skill_name: str) -> bool:
    """Sync a skill from source to dotfiles. Returns success."""
    src = find_skill_source(skill_name)
    if not src:
        print(f"  ✗ Source not found: {skill_name}")
        return False

    actual_skill = skill_name.rsplit("/", 1)[-1] if "/" in skill_name else skill_name
    dest = DOTFILES_SKILLS / actual_skill

    # Remove old and copy new
    if dest.exists():
        _ = subprocess.run(["rm", "-rf", str(dest)], check=True)

    _ = subprocess.run(["cp", "-a", str(src), str(dest)], check=True)

    # Remove .git if it was copied (e.g. if skill is at repo root)
    dot_git = dest / ".git"
    if dot_git.exists():
        _ = subprocess.run(["rm", "-rf", str(dot_git)], check=True)

    print(f"  ✓ Synced: {skill_name}")
    return True





def cmd_status() -> None:
    """Show current state."""
    repos = discover_cached_repos()

    if not repos:
        print(f"No cached repos found in {CACHE_ROOT}")
        print("Use 'add' command to clone repos, or clone manually to that location.")
        return

    all_skills: set[str] = set()

    print(f"\nDiscovered repos ({len(repos)}):")
    for repo_path in repos:
        print(f"  {repo_path}")
        skills = get_repo_skills(repo_path)
        for skill in skills:
            all_skills.add(skill)
            dotfiles_path = DOTFILES_SKILLS / skill
            status = "✓" if dotfiles_path.exists() else "?"
            print(f"    {status} {skill}")

    print(f"\n{len(all_skills)} unique skill(s) found")
    print(f"Dotfiles skills: {DOTFILES_SKILLS}")


def cmd_check() -> None:
    """Check which skills need updating."""
    all_skills = get_all_skills_with_source()

    if not all_skills:
        print("No skills found in cached repos.")
        return

    print(f"\nChecking {len(all_skills)} skill(s)...\n")

    outdated: list[str] = []
    for skill in sorted(all_skills):
        source = find_skill_source(skill)
        if not source:
            print(f"  ? {skill}: source not found")
            continue

        if needs_update(skill):
            print(f"  ↑ {skill}: needs update")
            outdated.append(skill)
        else:
            print(f"  ✓ {skill}: up to date")

    if outdated:
        print(f"\n{len(outdated)} skill(s) need updating. Run 'sync <skill>' to update.")
    else:
        print("\nAll skills are up to date.")


def cmd_sync(specific_skills: list[str] | None = None) -> None:
    """Sync skills and commit to dotfiles."""
    if not specific_skills:
        print("Error: No skills specified. Use 'sync <skill1> <skill2>...' or 'select'.")
        return

    all_skills = set()
    for s in specific_skills:
        if "/" in s:
            src = find_skill_source(s)
            sources = [src] if src else []
        else:
            sources = find_skill_sources(s)

        if len(sources) > 1:
            print(f"Warning: Multiple sources found for '{s}':")
            for src in sources:
                try:
                    rel = src.relative_to(CACHE_ROOT)
                    parts = rel.parts
                    source_str = f"{parts[0]}/{parts[1]}/{s}" if len(parts) >= 2 else f"{str(rel)}/{s}"
                    print(f"  - {source_str}")
                except ValueError:
                    print(f"  - {src}")
            print("Please specify the exact source to sync (e.g., syncr sync owner/repo/skill)")
            return
        elif len(sources) == 1:
            all_skills.add(s)
        else:
            print(f"Error: Source not found for '{s}'")
            return

    print(f"Syncing {len(all_skills)} specified skill(s)...\n")

    if not all_skills:
        print("No skills to sync.")
        return

    # Find outdated skills
    outdated: list[str] = [s for s in all_skills if needs_update(s)]

    if not outdated:
        print("All specified skills are already up to date.")
        return

    print(f"Found {len(outdated)} skill(s) to update...\n")

    # Sync each skill
    synced: list[str] = []
    for skill in outdated:
        if sync_skill(skill):
            synced.append(skill)

    if not synced:
        print("\nNo skills were synced.")
        return

    # Git operations
    print("\nCommitting to dotfiles...")
    try:
        _ = subprocess.run(
            [
                "git",
                "-C",
                str(DOTFILES_SKILLS.parent.parent),
                "add",
                "dot_agents/skills",
            ],
            check=True,
        )

        skill_list = ", ".join(synced)
        commit_msg = (
            f"Update skills: {skill_list}"
            if len(synced) <= 3
            else f"Update {len(synced)} skills"
        )

        result = subprocess.run(
            [
                "git",
                "-C",
                str(DOTFILES_SKILLS.parent.parent),
                "commit",
                "-m",
                commit_msg,
            ],
            capture_output=True,
            text=True,
        )

        if result.returncode == 0:
            print(f"  ✓ Committed: {commit_msg}")
        else:
            if "nothing to commit" in result.stderr.lower():
                print("  (no changes to commit)")
            else:
                print(f"  ✗ Commit failed: {result.stderr}")
    except subprocess.CalledProcessError as e:
        print(f"  ✗ Git operation failed: {e}")


def get_all_skills_with_source() -> list[str]:
    """Collect all skills as org/repo/skill strings."""
    repos = discover_cached_repos()
    all_skills = []

    for repo_path in repos:
        skills = get_repo_skills(repo_path)
        try:
            rel = repo_path.relative_to(CACHE_ROOT)
            parts = rel.parts
            prefix = f"{parts[0]}/{parts[1]}" if len(parts) >= 2 else str(rel)
        except ValueError:
            prefix = str(repo_path.name)
        
        for skill in skills:
            all_skills.append(f"{prefix}/{skill}")

    return sorted(all_skills)

def cmd_select() -> list[str] | None:
    """Interactively select skills to sync. Returns list of selected skill names."""
    all_skills = get_all_skills_with_source()

    if not all_skills:
        print("No skills found in cached repos.")
        return None

    print(f"\nFound {len(all_skills)} skill(s):\n")

    for i, full_skill in enumerate(all_skills, 1):
        skill_name = full_skill.split("/")[-1]
        dotfiles_path = DOTFILES_SKILLS / skill_name
        status = "✓" if dotfiles_path.exists() else "?"
        print(f"  {i}. [{status}] {full_skill}")

    print("\nEnter skill numbers to sync (comma-separated, e.g., 1,3,5)")
    print("Or press Enter to cancel:")

    try:
        selection = input("> ").strip()
    except (EOFError, KeyboardInterrupt):
        print("\nCancelled.")
        return None

    if not selection:
        print("Cancelled.")
        return None

    # Parse comma-separated numbers
    selected: list[str] = []
    for item in selection.split(","):
        item = item.strip()
        if not item:
            continue
        try:
            idx = int(item) - 1
            if 0 <= idx < len(all_skills):
                selected.append(all_skills[idx])
            else:
                print(f"Warning: {item} is out of range, skipping")
        except ValueError:
            # Try to match as skill name
            if item in all_skills:
                selected.append(item)
            else:
                print(f"Warning: '{item}' not found, skipping")

    if not selected:
        print("No valid skills selected.")
        return None

    return selected


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Sync agent skills from cached repos to dotfiles",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Manages repos in ~/.cache/syncr/ and syncs their skills to dotfiles.

Examples:
  syncr add owner/repo           # clone a repo
  syncr status                   # show all repos and skills
  syncr check                    # check what needs updating
  syncr pull                     # pull latest changes for all repos
  syncr sync skill1 skill2       # sync specific skills
  syncr select                   # interactively choose skills
        """,
    )

    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # add command
    add_parser = subparsers.add_parser("add", help="Clone a repo to the cache")
    _ = add_parser.add_argument(
        "repo", help="Repo URL (owner/repo, https://..., git@...)"
    )

    _ = subparsers.add_parser("status", help="Show discovered repos and skills")
    _ = subparsers.add_parser("check", help="Check for skill updates")
    _ = subparsers.add_parser("pull", help="Pull changes from remotes for all cached repos")

    sync_parser = subparsers.add_parser("sync", help="Sync skills and commit")
    _ = sync_parser.add_argument(
        "skills", nargs="*", help="Specific skills to sync"
    )

    _ = subparsers.add_parser("select", help="Interactively select skills to sync")

    args = parser.parse_args()

    command = cast(str | None, args.command)
    if not command:
        parser.print_help()
        sys.exit(1)

    if not DOTFILES_SKILLS.exists():
        print(f"Error: Dotfiles skills directory not found: {DOTFILES_SKILLS}")
        sys.exit(1)

    if command == "add":
        repo_input = cast(str, args.repo)
        cmd_add(repo_input)
    elif command == "status":
        cmd_status()
    elif command == "check":
        cmd_check()
    elif command == "pull":
        cmd_pull()
    elif command == "sync":
        skills_arg = cast(list[str], args.skills)
        specific_skills = skills_arg if skills_arg else None
        cmd_sync(specific_skills)
    elif command == "select":
        selected = cmd_select()
        if selected:
            cmd_sync(selected)


if __name__ == "__main__":
    main()

