#!/usr/bin/env bash
# Auto-switches DMS display profiles based on the current resolution of the XG27UCG monitor.
# Only for Linux gaming with CachyOS, Niri, and DMS.
# For automatic switching, enable/start the dms-auto-resolution-profile systemd user service.

MONITOR_MODEL="XG27UCG"

PROFILE_4K="asus-xg27ucg-4k"
PROFILE_1080="asus-xg27ucg-1080"

get_niri_socket() {
  if [[ -n "${NIRI_SOCKET:-}" && -S "${NIRI_SOCKET}" ]]; then
    printf '%s\n' "$NIRI_SOCKET"
    return 0
  fi

  find "${XDG_RUNTIME_DIR:-/run/user/$UID}" -maxdepth 1 -type s -name 'niri.*.sock' 2>/dev/null | head -n 1
}

get_resolution() {
  local socket

  socket="$(get_niri_socket)"
  [[ -n "$socket" ]] || return 0

  NIRI_SOCKET="$socket" niri msg --json outputs 2>/dev/null | jq -r \
    --arg model "$MONITOR_MODEL" '
      to_entries[]
      | select(.value.model == $model)
      | .value as $output
      | $output.modes[$output.current_mode]
      | "\(.width)x\(.height)"
    '
}

get_active_profile() {
  dms ipc outputs status | awk '/^active:/ {print $2}'
}

apply_profile_if_needed() {
  local res active target

  res="$(get_resolution)"
  active="$(get_active_profile)"

  case "$res" in
    3840x2160)
      target="$PROFILE_4K"
      ;;
    1920x1080)
      target="$PROFILE_1080"
      ;;
    *)
      return 0
      ;;
  esac

  if [[ "$active" != "$target" ]]; then
    dms ipc outputs setProfile "$target"
  fi
}

while true; do
  apply_profile_if_needed
  sleep 2
done
