# ============================================================================
# INITIALIZATION
# ============================================================================

# uncomment to profile zsh startup, along with zprof (end of line)
# zmodload zsh/zprof

eval "$(starship init zsh)"

# Homebrew setup
if [[ -f "/opt/homebrew/bin/brew" ]] then
  # If you're using macOS, you'll want this enabled
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# ============================================================================
# PLUGIN MANAGEMENT
# ============================================================================

# Zinit setup
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"

# Zinit installation
if [ ! -d "$ZINIT_HOME" ]; then
   mkdir -p "$(dirname $ZINIT_HOME)"
   git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

# Load zinit
source "${ZINIT_HOME}/zinit.zsh"

# Plugins
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light Aloxaf/fzf-tab

# ============================================================================
# EXTERNAL TOOLS
# ============================================================================

# fzf - fuzzy finder
source <(fzf --zsh)

# zoxide - smart cd
eval "$(zoxide init --cmd cd zsh)"

# ============================================================================
# SHELL CONFIGURATION
# ============================================================================

# Completions
autoload -Uz compinit && compinit

# Keybindings
bindkey -e
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^[w' kill-region

# Other settings
DISABLE_AUTO_TITLE=true
ulimit -n 10240

# History settings
HISTSIZE=100000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
# HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups

# Completion styling
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color $realpath'

# ============================================================================
# ENVIRONMENT
# ============================================================================

# General paths
export COLORTERM=truecolor
export PATH=$PATH:$HOME/.local/bin/
export PATH=$PATH:$HOME/bin/
export PATH=$PATH:$HOME/go/bin
export PATH=$PATH:$HOME/.cargo/bin/
export PATH=/opt/homebrew/share/google-cloud-sdk/bin:"$PATH"
# export AKKIO_REPOSITORY_PATH=$HOME/repos/Akkio/

export EDITOR=nvim

# Akkio stuff
export PROC_COMP_CONFIG="$HOME/.config/process-compose"

CLAUDE_CODE_NO_FLICKER=1

# ============================================================================
# ALIASES
# ============================================================================

alias ls='eza'
alias lg='lazygit'
alias ld='lazydocker'
alias v='nvim'
alias o='opencode'
alias ff='fastfetch'
alias t='tmux'
alias c='claude --dangerously-skip-permissions'
alias gds='git --no-pager diff --stat HEAD'
alias chrome-debug='/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --remote-debugging-port=9222'
# alias ag='Xvfb :100 -screen 0 1920x1080x24 & sleep 1 && DISPLAY=:100 autocutsel -fork & DISPLAY=:100 antigravity --ozone-platform=x11 & sleep 2 && x11vnc -display :100 -forever -rfbauth ~/.vnc/passwd -listen 0.0.0.0 -rfbport 5900 -noxdamage -clipboard'


# ============================================================================
# MY FUNCTIONS
# ============================================================================


# ============================================================================
# system-generated fluff
# ============================================================================

# Added by Antigravity
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# mise
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"


