#!/usr/bin/env bash
# Focus the tmux location that produced a Pi notification.
# Called by terminal-notifier -execute with: socket session window pane.

set -euo pipefail

if (( $# < 4 )); then
	exit 0
fi

socket=$1
session=$2
window=$3
pane=$4

tmux_bin=""
for candidate in tmux /opt/homebrew/bin/tmux /usr/local/bin/tmux; do
	if command -v "$candidate" >/dev/null 2>&1; then
		tmux_bin=$candidate
		break
	fi
done

if [[ -z $tmux_bin ]]; then
	exit 0
fi

# Use the same order as the working Claude hook: select the saved window/pane,
# then switch the attached client back to the saved session.
"$tmux_bin" -S "$socket" select-window -t "$window" >/dev/null 2>&1 || true
"$tmux_bin" -S "$socket" select-pane -t "$pane" >/dev/null 2>&1 || true
"$tmux_bin" -S "$socket" switch-client -t "$session" >/dev/null 2>&1 || true
