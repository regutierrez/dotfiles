# ============================================================================
# INITIALIZATION
# ============================================================================

# uncomment to profile zsh startup, along with zprof (end of line)
# zmodload zsh/zprof

eval "$(starship init zsh)"
if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init zsh)"
fi
{{- if eq .chezmoi.os "darwin" }}

# Homebrew setup
if [[ -f "/opt/homebrew/bin/brew" ]] then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{{- end }}

# ============================================================================
# PLUGIN MANAGEMENT
# ============================================================================

# Zinit setup
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"

# Zinit installation
if [ ! -d "$ZINIT_HOME" ]; then
   mkdir -p "$(dirname $ZINIT_HOME)"
   git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

# Load zinit
source "${ZINIT_HOME}/zinit.zsh"

# Plugins
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light Aloxaf/fzf-tab

# ============================================================================
# EXTERNAL TOOLS
# ============================================================================

# fzf - fuzzy finder
source <(fzf --zsh)

# zoxide - smart jump
{{- if eq .chezmoi.os "darwin" }}
eval "$(zoxide init --cmd z zsh)"
{{- else }}
eval "$(zoxide init --cmd cd zsh)"
{{- end }}

# ============================================================================
# SHELL CONFIGURATION
# ============================================================================

# Completions
autoload -Uz compinit && compinit

# Keybindings
bindkey -e
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^[w' kill-region

# Tmux extended-keys sends Shift+Enter as CSI-u; make zsh treat it as Enter.
if [[ -n "$TMUX" ]]; then
  bindkey $'\e[13;2u' accept-line
  bindkey $'\e[27;2;13~' accept-line
fi

# Other settings
DISABLE_AUTO_TITLE=true
{{- if eq .chezmoi.os "darwin" }}
ulimit -n 10240
{{- end }}

# History settings
HISTSIZE=100000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
# HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups

# Completion styling
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color $realpath'

# ============================================================================
# ENVIRONMENT
# ============================================================================

# General paths
export COLORTERM=truecolor
export PATH=$PATH:$HOME/.local/bin/
export PATH=$PATH:$HOME/bin/
export PATH=$PATH:$HOME/go/bin
export PATH=$PATH:$HOME/.cargo/bin/
export PATH=$PATH:$HOME/.opencode/bin
export PATH=$HOME/.npm-global/bin:$PATH # allows me to run node pkg globally installed
{{- if eq .chezmoi.os "darwin" }}
export PATH=$PATH:$HOME/Library/Android/sdk/platform-tools/
export PATH=/opt/homebrew/share/google-cloud-sdk/bin:"$PATH"
export PATH=/opt/homebrew/opt/libpq/bin:"$PATH"
{{- end }}

export EDITOR=nvim
{{- if eq .profile "work" }}

# Akkio stuff
export PROC_COMP_CONFIG="$HOME/.config/process-compose"
{{- end }}

CLAUDE_CODE_NO_FLICKER=1

# ============================================================================
# ALIASES
# ============================================================================

alias ls='eza'
alias lg='lazygit'
alias ld='lazydocker'
alias v='nvim'
alias o='opencode'
alias ff='fastfetch'
alias t='tmux'
alias c='claude --dangerously-skip-permissions'
alias co='commando'
alias ca='chezmoi apply'
alias noco='ssh -t noco tmux -u a'
alias sbs='ssh -t sbs@sbs-cloud tmux -u a'
alias esquie='ssh -t esquie tmux -u a'
alias gds='git --no-pager diff --stat HEAD'
{{- if eq .chezmoi.os "darwin" }}
alias chrome-debug='/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --remote-debugging-port=9222 --user-data-dir=/tmp/chrome-perf-profile > /tmp/chrome.log 2>&1 &'
{{- end }}
alias dbui='nvim -c DBUI'
# alias ag='Xvfb :100 -screen 0 1920x1080x24 & sleep 1 && DISPLAY=:100 autocutsel -fork & DISPLAY=:100 antigravity --ozone-platform=x11 & sleep 2 && x11vnc -display :100 -forever -rfbauth ~/.vnc/passwd -listen 0.0.0.0 -rfbport 5900 -noxdamage -clipboard'


# ============================================================================
# MY FUNCTIONS
# ============================================================================


# ============================================================================
# system-generated fluff
# ============================================================================

# Added by Antigravity
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# mise
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi

# fnm
FNM_PATH="$HOME/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
  export PATH="$FNM_PATH:$PATH"
fi
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd --shell zsh)"
fi

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Always prefer the canonical global pi install over fnm/mise/bun shims.
# fnm re-prepends its multishell bin on directory changes, so enforce this once
# at startup and again after every chpwd hook run.
__prefer_npm_global_pi() {
  typeset -gU path PATH
  path=("$HOME/.npm-global/bin" ${path:#$HOME/.npm-global/bin})
  rehash
}
autoload -Uz add-zsh-hook
__prefer_npm_global_pi
add-zsh-hook chpwd __prefer_npm_global_pi

# uncomment to profile zsh startup, along with zprof (end of line)
# zprof

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi
