{{- $profile := (index . "profile" | default "desktop") -}}
{{- $cfg := ((index .profiles $profile) | default (index .profiles "desktop")) -}}

# Add binding to reload tmux.conf
bind r source-file ~/.tmux.conf \; display ".conf reloaded"
bind ? display-popup -E "tmux list-keys | fzf --ansi --layout=reverse --prompt='tmux keybindings> '"

# Remap prefix
set -g prefix `
bind ` send-prefix
set -g extended-keys on
set -g extended-keys-format csi-u

# use opt + hjkl to navigate through panes
bind -n M-h select-pane -L
bind -n M-j select-pane -D
bind -n M-k select-pane -U
bind -n M-l select-pane -R

# session shortcuts
bind N new-session -c "#{pane_current_path}"
bind R command-prompt -p "rename session to:" "rename-session '%%'"

# clear old alt+arrow resize bindings (important on config reload)
unbind -nq M-Left
unbind -nq M-Down
unbind -nq M-Up
unbind -nq M-Right

# resize pane with alt + shift + hjkl
bind -nr M-H resize-pane -L 5
bind -nr M-J resize-pane -D 5
bind -nr M-K resize-pane -U 5
bind -nr M-L resize-pane -R 5
set -s escape-time 0

# mouse support on
set -g mouse on

set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",*:RGB"

# increase history
set-option -g history-limit 50000

# change split bindings
bind \\ split-window -hc "#{pane_current_path}"
bind - split-window -vc "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on

# vi copy mode
set-window-option -g mode-keys vi

# Enter copy mode with prefix+v
bind v copy-mode

# Copy mode navigation and selection (vim-style)
bind -T copy-mode-vi q send-keys -X cancel
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi V send-keys -X select-line
bind -T copy-mode-vi Escape send-keys -X clear-selection
bind -T copy-mode-vi 'C-v' send-keys -X rectangle-toggle
bind -T copy-mode-vi y send-keys -X copy-selection-and-cancel
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-selection-and-cancel

set -g set-clipboard on
set -g focus-events on
set -g allow-passthrough on

set -g status-left-length 100
set -g status-right-length 100
set -g automatic-rename off
set -g allow-rename off

# plugins
{{- if $cfg.tmux_plugins }}
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'catppuccin/tmux#v2.1.3'
set -g @catppuccin_flavor 'mocha'
set -g @catppuccin_window_status_style 'rounded'
set -g @catppuccin_pane_status_enabled 'no'
set -g pane-border-status top
set -g @catppuccin_pane_border_style 'fg=#{@thm_surface_0}'
set -g @catppuccin_pane_active_border_style ''

# auto-install TPM if missing
if "test ! -d ~/.tmux/plugins/tpm" \
   "run 'git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm && ~/.tmux/plugins/tpm/bin/install_plugins'"
{{- end }}

{{- if $cfg.tmux_plugins }}
# load catppuccin before status module configuration
if-shell "test -f ~/.tmux/plugins/tmux/catppuccin.tmux" \
  "run '~/.tmux/plugins/tmux/catppuccin.tmux'"

# subtle pane numbers in the top border, no background fill
set -g pane-border-format '#{?pane_active,#[fg=#{@thm_lavender}],#[fg=#{@thm_surface_0}]}#{pane_index}'

# pane border: red when panes are synced, lavender otherwise
set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"
set-hook -g client-session-changed 'set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"'
set-hook -g after-select-window 'set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"'
set-hook -g after-select-pane 'set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"'
set-hook -g window-pane-changed 'set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"'

# window title with zoom indicator (ZOOMED shows in red when zoomed)
set -g @catppuccin_window_current_text " #W#{?window_zoomed_flag, #[fg=#{@thm_red}]ZOOMED,}"
set -g @catppuccin_window_text " #W#{?window_zoomed_flag, #[fg=#{@thm_red}]ZOOMED,}"



# remove tmux's default pane title on the right and use catppuccin modules instead
set -g status-left ""
set -ag status-left "#{E:@catppuccin_status_session}"
set -g status-right "#{E:@catppuccin_status_date_time}"
set -ag status-right "#{E:@catppuccin_status_uptime}"

{{- end }}

# custom commands
bind o display-popup -E -w 50 -h 15 ~/bin/commando
bind S setw synchronize-panes \; set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"
set-option -g status-position top

{{- if $cfg.tmux_plugins }}
run '~/.tmux/plugins/tpm/tpm'
{{- end }}
