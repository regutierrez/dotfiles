{{- $profile := (index . "profile" | default "personal") -}}
{{- $cfg := ((index .profiles $profile) | default (index .profiles "personal")) -}}

# vim: set ft=tmux:

# Core behavior
set -s escape-time 0
set -g history-limit 50000
set -g display-time 4000
set -g status-interval 5
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",*:RGB"

# Extended keys / focus / clipboard
set -s extended-keys on
set -s extended-keys-format csi-u
set -s terminal-features 'xterm*:clipboard:ccolour:cstyle:focus:title'
set -as terminal-features 'screen*:title'
set -as terminal-features 'rxvt*:ignorefkeys'
set -g focus-events on
set -g set-clipboard on
set -gq allow-passthrough all

# Prompt/editing behavior
set -g status-keys emacs
setw -g aggressive-resize on

# Prefix
unbind C-b
set -g prefix `
bind ` send-prefix

# Reload / key help
bind r source-file ~/.tmux.conf \; display ".conf reloaded"
bind ? display-popup -E "tmux list-keys | fzf --ansi --layout=reverse --prompt='tmux keybindings> '"

# Mouse
set -g mouse on

# Pane navigation
bind -n M-h select-pane -L
bind -n M-j select-pane -D
bind -n M-k select-pane -U
bind -n M-l select-pane -R

# Pane resize
unbind -nq M-Left
unbind -nq M-Down
unbind -nq M-Up
unbind -nq M-Right
bind -nr M-H resize-pane -L 5
bind -nr M-J resize-pane -D 5
bind -nr M-K resize-pane -U 5
bind -nr M-L resize-pane -R 5

# Sessions/windows
bind N new-session -c "#{pane_current_path}"
bind R command-prompt -p "rename session to:" "rename-session '%%'"
bind , command-prompt -p "rename window to:" "rename-window '%%'"

# Splits/windows keep cwd
unbind %
unbind '"'
bind \\ split-window -hc "#{pane_current_path}"
bind - split-window -vc "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"

# Pane/window numbering
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on

# Copy mode
setw -g mode-keys vi
bind v copy-mode
bind -T copy-mode-vi q send-keys -X cancel
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi V send-keys -X select-line
bind -T copy-mode-vi Escape send-keys -X clear-selection
bind -T copy-mode-vi 'C-v' send-keys -X rectangle-toggle
{{- if eq .chezmoi.os "darwin" }}
bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe "pbcopy"
{{- else }}
bind -T copy-mode-vi y send-keys -X copy-selection-and-cancel
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-selection-and-cancel
{{- end }}

# Status/general
set -g visual-activity off
set -g automatic-rename off
set -g allow-rename off
set -g status-left-length 100
set -g status-right-length 100
set-option -g status-position top

{{- if $cfg.tmux_plugins }}

# Plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'catppuccin/tmux#v2.1.3'

# Resurrect / continuum
set -g @resurrect-strategy-vim 'session'
set -g @resurrect-strategy-nvim 'session'
# tmux-resurrect stores both the foreground process (`node`) and the command
# originally launched in the pane (`pi`). Restore matching uses the saved command,
# so match `pi` and continue the latest project session.
set -g @resurrect-processes '"pi->pi -c"'
set -g @resurrect-capture-pane-contents 'on'
set -g @continuum-restore 'on'
set -g @continuum-save-interval '10'

# Catppuccin
set -g @catppuccin_flavor 'mocha'
set -g @catppuccin_window_status_style 'rounded'
set -g @catppuccin_pane_status_enabled 'no'
set -g pane-border-status top
set -g @catppuccin_pane_border_style 'fg=#{@thm_surface_0}'
set -g @catppuccin_pane_active_border_style ''

# Install mutable TPM checkouts outside the chezmoi-managed tree.
set-environment -g TMUX_PLUGIN_MANAGER_PATH '~/.local/share/tmux/plugins'

# Auto-install TPM
if "test ! -d ~/.local/share/tmux/plugins/tpm" \
   "run 'mkdir -p ~/.local/share/tmux/plugins && git clone https://github.com/tmux-plugins/tpm ~/.local/share/tmux/plugins/tpm && ~/.local/share/tmux/plugins/tpm/bin/install_plugins'"

# Load catppuccin before status config
if-shell "test -f ~/.local/share/tmux/plugins/tmux/catppuccin.tmux" \
  "run '~/.local/share/tmux/plugins/tmux/catppuccin.tmux'"

# Pane border/status
set -g pane-border-format '#{?pane_active,#[fg=#{@thm_lavender}],#[fg=#{@thm_surface_0}]}#{pane_index}'
set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"

set-hook -g client-session-changed 'set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"'
set-hook -g after-select-window 'set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"'
set-hook -g after-select-pane 'set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"'
set-hook -g window-pane-changed 'set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"'

# Window title with zoom indicator
set -g @catppuccin_window_current_text " #W#{?window_zoomed_flag, #[fg=#{@thm_red}]ZOOMED,}"
set -g @catppuccin_window_text " #W#{?window_zoomed_flag, #[fg=#{@thm_red}]ZOOMED,}"

# Status modules
set -g status-left ""
set -ag status-left "#{E:@catppuccin_status_session}"
set -g status-right "#{E:@catppuccin_status_host}"
set -ag status-right "#{E:@catppuccin_status_date_time}"
set -ag status-right "#{E:@catppuccin_status_uptime}"

{{- end }}

# Custom commands
bind o run-shell '~/bin/commando --fzf-tmux'
bind a display-popup -E -w 80% -h 75% -T " agent sessions " '~/bin/agent-sessions-picker'
bind -r DC select-layout tiled
bind S setw synchronize-panes \; set -g pane-active-border-style "#{?synchronize-panes,fg=#{@thm_red},fg=#{@thm_lavender}}"

{{- if $cfg.tmux_plugins }}
run '~/.local/share/tmux/plugins/tpm/tpm'

# Override theme copy-mode selection
set -g mode-style "fg=#{@thm_bg},bg=#{@thm_green}"
{{- end }}
