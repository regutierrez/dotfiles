{{- $profile := (index . "profile" | default "personal") -}}
{{- $bootstrap := (index . "bootstrap" | default false) -}}

{{- /* Define default config in case .profiles is not available during init */ -}}
{{- $cfg := (dict "use_age" true "manage_bashrc" false "manage_vimrc" false "manage_nvim" true "manage_bin" true "manage_dot_config" true "manage_agents" true) -}}
{{- if eq $profile "server" -}}
{{-   $cfg = (dict "use_age" true "manage_bashrc" true "manage_vimrc" true "manage_nvim" false "manage_bin" false "manage_dot_config" false "manage_agents" true) -}}
{{- else if eq $profile "work" -}}
{{-   $cfg = (dict "use_age" false "manage_bashrc" false "manage_vimrc" false "manage_nvim" true "manage_bin" true "manage_dot_config" true "manage_agents" true) -}}
{{- end -}}

{{- /* Override with actual profile data if available */ -}}
{{- if index . "profiles" -}}
{{-   $cfg = (index .profiles $profile) -}}
{{- end -}}

{{- $use_age := $cfg.use_age -}}

