{{- $profile := (index . "profile" | default "personal") -}}

{{- /* Define default config in case .profiles is not available during init */ -}}
{{- $cfg := (dict "use_age" true "manage_bashrc" false "manage_vimrc" false "manage_bin" true "manage_dot_config" true "manage_agents" true "tmux_plugins" true) -}}
{{- if eq $profile "server" -}}
{{-   $cfg = (dict "use_age" true "manage_bashrc" true "manage_vimrc" true "manage_bin" false "manage_dot_config" false "manage_agents" false "tmux_plugins" false) -}}
{{- else if eq $profile "work" -}}
{{-   $cfg = (dict "use_age" false "manage_bashrc" false "manage_vimrc" false "manage_bin" true "manage_dot_config" true "manage_agents" true "tmux_plugins" true) -}}
{{- end -}}

{{- /* Override with actual profile data if available */ -}}
{{- if index . "profiles" -}}
{{-   $cfg = (index .profiles $profile) -}}
{{- end -}}

{{- $use_age := $cfg.use_age -}}

README.md
AGENTS.md
TODO.md
LICENSE
archive/
macos/
linux/
srv/

{{- if ne .chezmoi.os "darwin" }}
.ssh/id_ed25519
.ssh/id_ed25519.pub
.ssh/config
.config/karabiner
.config/zed
{{- end }}

{{- if not $use_age }}
**/*.age
**/*.age.tmpl
{{- end }}

{{- if not $cfg.manage_bashrc }}
.bashrc
{{- end }}

{{- if not $cfg.manage_vimrc }}
.vimrc
{{- end }}

{{- if not $cfg.manage_bin }}
bin/
{{- end }}

{{- if not $cfg.manage_dot_config }}
.config/
{{- end }}

{{- if not $cfg.manage_agents }}
.agents/
{{- end }}

{{- if not $cfg.tmux_plugins }}
.tmux/plugins/
{{- end }}

