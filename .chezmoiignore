{{- $profile := (index . "profile" | default "personal") -}}
{{- /* Keep existing CachyGaming machines working after the profile was folded into personal. */ -}}
{{- if eq $profile "cachygaming" -}}
{{-   $profile = "personal" -}}
{{- end -}}
{{- $server := eq $profile "server" -}}
{{- $skillGroups := list "shared" "desktop" -}}
{{- if eq $profile "work" -}}
{{-   $skillGroups = list "shared" "work" "desktop" -}}
{{- else if $server -}}
{{-   $skillGroups = list "shared" -}}
{{- end -}}

