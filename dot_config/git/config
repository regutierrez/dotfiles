[branch]
	sort = -committerdate

[column]
	ui = auto

[fetch]
	prune = true
	writeCommitGraph = true

[init]
	defaultBranch = main

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = true

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[pull]
	rebase = true

[rebase]
	updateRefs = true

[rerere]
	enabled = true

[alias]
	branch-age = "for-each-ref --sort=committerdate refs/heads/ --format=%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))"
	nuke = "!git add --all && git stash && git stash clear"
