// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      // "j k": ["workspace::SendKeystrokes", "escape"]
    }
  },
  {
    "bindings": {
      "cmd-`": "terminal_panel::ToggleFocus",
      "cmd-\\": "workspace::ToggleLeftDock",
      "cmd-?": "workspace::ToggleRightDock",
      "cmd-|": "multi_workspace::ToggleWorkspaceSidebar",
      "cmd-:": "multi_workspace::FocusWorkspaceSidebar",
      "cmd-shift-g": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-\\": "pane::SplitRight",
      "cmd-|": "editor::MoveToEnclosingBracket"
    },
    "bindings": {
      "cmd-\\": "workspace::ToggleLeftDock",
      "cmd-?": "workspace::ToggleRightDock",
      "cmd-[": null
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-b": "workspace::ToggleLeftDock",
      "cmd-r": "workspace::ToggleRightDock",
      "cmd-alt-b": "workspace::ToggleRightDock",
      "cmd-?": "agent::ToggleFocus",
      "cmd-alt-j": "multi_workspace::ToggleWorkspaceSidebar",
      "cmd-alt-;": "multi_workspace::FocusWorkspaceSidebar"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-[": "pane::GoBack"
    }
  },
  {
    "context": "ThreadHistory",
    "bindings": {
      "cmd-[": "pane::GoBack"
    }
  },
  {
    "context": "AgentConfiguration",
    "bindings": {
      "cmd-[": "pane::GoBack"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl--": null
    }
  },
  {
    "context": "ThreadHistory",
    "bindings": {
      "ctrl--": null
    }
  },
  {
    "context": "AgentConfiguration",
    "bindings": {
      "ctrl--": null
    }
  }
]
