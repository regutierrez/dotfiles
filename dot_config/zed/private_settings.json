// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "amp-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "pi-acp": {
      "type": "registry"
    }
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "ui_font_weight": 400.0,
  "agent": {
    "dock": "left",
    "default_profile": "ask",
    "model_parameters": [],
  },
  "telemetry": {
    "metrics": false,
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "ui_font_size": 13.0,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark",
  },
}
