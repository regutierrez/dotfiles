<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.regutierrez.ghostty-tmux</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>exec /bin/bash "$HOME/.config/tmux/start-ghostty-tmux.sh"</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
